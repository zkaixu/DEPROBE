# Publish only the source scripts and top-level docs. Everything else
# (datasets, model checkpoints, logs, results, scratch directories) stays
# local: it is neither committed nor named here, so the repository does not
# expose the project's working layout.

# Ignore every top-level entry by default.
/*

# Re-include only what is meant to be public.
!/scripts/
!/README.md
!/setup_env.sh
!/.gitignore
!/LICENSE
!/pixi.toml
!/pyproject.toml

# Drop Python bytecode caches even inside the published tree.
__pycache__/
*.pyc
*.pyo
